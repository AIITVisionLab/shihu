[Unit]
Description=go2rtc K230 Video Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=linaro
Group=linaro
WorkingDirectory=/home/linaro/project/EdgeLink_RK3568
ExecStart=/usr/local/bin/go2rtc -config /home/linaro/project/EdgeLink_RK3568/config/go2rtc.yaml
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
