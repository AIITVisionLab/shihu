                "${workspaceFolder}/mcu/bsp/systick/Inc",
                "${workspaceFolder}/mcu/bsp/ETH/Inc",
                "${workspaceFolder}/mcu/bsp/rs485/Inc",

                // APP 头文件
                "${workspaceFolder}/mcu/app/app_data/Inc",
                "${workspaceFolder}/mcu/app/app_lwip/Inc",
                "${workspaceFolder}/mcu/app/app_uplink/Inc",
                "${workspaceFolder}/mcu/app/task_uplink/Inc",
                "${workspaceFolder}/mcu/app/task_modbus_master/Inc",

