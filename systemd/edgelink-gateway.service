[Unit]
Description=EdgeLink RK3568 Stage-1 Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=linaro
Group=linaro
WorkingDirectory=/home/linaro/project/EdgeLink_RK3568
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 /home/linaro/project/EdgeLink_RK3568/src/edgelink_gateway.py --config /home/linaro/project/EdgeLink_RK3568/config/edgelink.ini
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
